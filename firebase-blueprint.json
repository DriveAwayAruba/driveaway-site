{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Represents a car rental booking request.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "car": { "type": "string" },
        "pickup": { "type": "string" },
        "arrival": { "type": "string" },
        "departure": { "type": "string" },
        "pickupTime": { "type": "string" },
        "flightNumber": { "type": "string" },
        "accommodationName": { "type": "string" },
        "airbnbName": { "type": "string" },
        "airbnbAddress": { "type": "string" },
        "specialInstructions": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled"] },
        "hasAfterHoursFee": { "type": "boolean" }
      },
      "required": ["name", "phone", "email", "car", "pickup", "arrival", "departure", "pickupTime", "createdAt", "status", "hasAfterHoursFee"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of travel booking requests."
    }
  }
}
